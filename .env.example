# Copy to .env and fill in. All values are optional — the app runs offline
# with sensible defaults if you leave these blank.

# --- API keys (enable live data instead of sample feed) ---
NEWSAPI_KEY=
ALPHAVANTAGE_KEY=

# --- NLP backend: auto | on | off ---
# auto  = use FinBERT if installed, else lexicon fallback
# off   = force fast lexicon fallback (good for low-resource demos)
USE_FINBERT=auto

# --- Database ---
DB_URL=sqlite:///signals.db
# Postgres example: postgresql://user:pass@localhost:5432/mie

# --- Decision / risk tuning (defaults shown) ---
CONFIDENCE_THRESHOLD=0.65
SENTIMENT_REVERSAL_EXIT=0.70
ATR_STOP_MULT=1.5
ATR_TARGET_MULT=2.5
TIME_EXIT_SESSIONS=3
RISK_PER_TRADE=0.02
